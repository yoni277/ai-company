{
  "name": "ai-company",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Native company operating system. Phase 1: Executive Dashboard + AI Chief of Staff.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @ai-company/executive-dashboard dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf node_modules .next dist",
    "chief:briefing": "pnpm --filter @ai-company/ai-chief-of-staff run cli:briefing"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  }
}
