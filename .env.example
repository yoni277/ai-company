# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (AI Chief of Staff)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Runtime
# Set to "mock" to run the dashboard entirely on in-memory data (no Supabase needed).
# Set to "supabase" once env vars above are filled in.
AI_COMPANY_DATA_MODE=mock

# Optional: control which connectors are active (comma-separated).
# Empty = all registered connectors.
AI_COMPANY_ACTIVE_CONNECTORS=
