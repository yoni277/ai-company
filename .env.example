# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: PostgREST schema. Defaults to ai_company.
SUPABASE_SCHEMA=ai_company

# FoodTruck-IL connector — defaults to the same Supabase project + service role
# as the platform DB. Set these if FoodTruck-IL lives in a separate project.
FOODTRUCK_SUPABASE_URL=
FOODTRUCK_SUPABASE_SERVICE_ROLE_KEY=

# AI Chief of Staff — provider precedence: Anthropic, then OpenAI, then FakeLlmClient.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Runtime
# Set to "mock" to run the dashboard entirely on in-memory data (no Supabase needed).
# Set to "supabase" once env vars above are filled in.
AI_COMPANY_DATA_MODE=mock

# Optional: control which connectors are active (comma-separated).
# Empty = all registered connectors.
AI_COMPANY_ACTIVE_CONNECTORS=

# Phase 2 — GitHub platform connector (read-only)
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo

# Phase 2 — health score inputs
FAILED_DEPLOYMENTS_COUNT=0
