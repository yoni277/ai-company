{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2023"],
    "jsx": "preserve",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@active-instance/instance-seed": ["../../instances/yoni-company/instance-seed.ts"],
      "@active-instance/instance-connectors": [
        "../../instances/yoni-company/instance-connectors.ts"
      ],
      "@active-instance/project-registry-seed": [
        "../../instances/yoni-company/project-registry-seed.ts"
      ],
      "@active-instance/project-executive-metadata": [
        "../../instances/yoni-company/project-executive-metadata.ts"
      ],
      "@active-instance/governance-policy": [
        "../../instances/yoni-company/governance-policy.ts"
      ],
      "@active-instance/research-capability": [
        "../../instances/yoni-company/research-capability.ts"
      ],
      "@ai-company/shared-types": ["../../packages/shared-types/src"],
      "@ai-company/database": ["../../packages/database/src"],
      "@ai-company/connector-framework": ["../../packages/connector-framework/src"],
      "@ai-company/ai-chief-of-staff": ["../../packages/ai-chief-of-staff/src"],
      "@ai-company/ai-cto": ["../../packages/ai-cto/src"],
      "@ai-company/ai-vp-marketing": ["../../packages/ai-vp-marketing/src"],
      "@ai-company/ai-cfo": ["../../packages/ai-cfo/src"],
      "@ai-company/ai-coo": ["../../packages/ai-coo/src"],
      "@ai-company/ai-vp-sales": ["../../packages/ai-vp-sales/src"],
      "@ai-company/ai-executive-team": ["../../packages/ai-executive-team/src"],
      "@ai-company/connector-foodtruck-il": ["../../connectors/foodtruck-il/src"],
      "@ai-company/connector-lab-os": ["../../connectors/lab-os/src"],
      "@ai-company/connector-inventory-engine": ["../../connectors/inventory-engine/src"],
      "@ai-company/connector-whatsapp-engine": ["../../connectors/whatsapp-engine/src"],
      "@ai-company/doos-core": ["../../packages/doos-core/src"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../instances/yoni-company/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
