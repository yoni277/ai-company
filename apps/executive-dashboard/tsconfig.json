{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2023"],
    "jsx": "preserve",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@ai-company/shared-types": ["../../packages/shared-types/src"],
      "@ai-company/database": ["../../packages/database/src"],
      "@ai-company/connector-framework": ["../../packages/connector-framework/src"],
      "@ai-company/ai-chief-of-staff": ["../../packages/ai-chief-of-staff/src"],
      "@ai-company/ai-cto": ["../../packages/ai-cto/src"],
      "@ai-company/ai-vp-marketing": ["../../packages/ai-vp-marketing/src"],
      "@ai-company/ai-cfo": ["../../packages/ai-cfo/src"],
      "@ai-company/ai-coo": ["../../packages/ai-coo/src"],
      "@ai-company/ai-vp-sales": ["../../packages/ai-vp-sales/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
